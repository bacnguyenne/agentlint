{
  "name": "agentlint-core",
  "version": "1.0.0",
  "description": "Validation & security engine for AI coding-agent configuration (Claude Code & MCP).",
  "license": "MIT",
  "author": "bacnguyenne (https://github.com/bacnguyenne)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bacnguyenne/agentlint.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/bacnguyenne/agentlint#readme",
  "bugs": "https://github.com/bacnguyenne/agentlint/issues",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:cov": "vitest run --coverage"
  },
  "dependencies": {
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vitest": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "@types/node": "^22.10.2"
  }
}

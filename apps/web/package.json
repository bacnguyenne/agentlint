{
  "name": "@agentlint/web",
  "version": "1.0.0",
  "private": true,
  "description": "agentlint studio — a free, open-source web UI to validate & security-check your AI coding-agent config.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "NEXT_DIST_DIR=.next-dev next dev -p 3100",
    "build": "next build",
    "start": "next start -p 3100",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "agentlint-core": "1.0.0",
    "next": "15.5.19",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "1.56.0",
    "@types/node": "22.10.2",
    "@types/react": "19.1.13",
    "@types/react-dom": "19.1.9",
    "@eslint/eslintrc": "3.2.0",
    "autoprefixer": "10.4.20",
    "eslint": "9.18.0",
    "eslint-config-next": "15.5.19",
    "postcss": "8.5.15",
    "tailwindcss": "3.4.17",
    "typescript": "5.7.2",
    "vitest": "4.1.9"
  }
}
